      "parameters": {
        "jsCode": "const body = $input.first().json.body;\nconst ratings = {};\n\nfor (const [key, value] of Object.entries(body)) {\n  if (key.startsWith('rating_')) {\n    const idx = key.replace('rating_', '');\n    ratings[idx] = parseInt(value) || 0;\n  }\n}\n\nreturn [{ json: { ratings } }];\n"
      },
